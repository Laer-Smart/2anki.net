= choicesRaw.length;\n\n  var data = { answered: {}, position: [] };\n  for (var i = 0; i < count; i++) { data.position.push(i); }\n  shuffleArray(data.position);\n\n  var k = \"value\";\n  var answer = \"\";\n  Persistence.setItem(\"scroll\", 0);\n  Persistence.setItem(\"answer\", \"\");\n\n  if (Persistence.getItem(\"Zoom\") == null) {\n    Persistence.setItem(\"Zoom\", 1);\n  }\n  var zoom = Persistence.getItem(\"Zoom\");\n  document.querySelectorAll(\".front\")[0].style.zoom = zoom;\n\n  function zoomIn() {\n    zoom += 0.1;\n    Persistence.setItem(\"Zoom\", zoom);\n    document.querySelectorAll(\".front\")[0].style.zoom = zoom;\n  }\n  function zoomDef() {\n    zoom = 1;\n    Persistence.setItem(\"Zoom\", zoom);\n    document.querySelectorAll(\".front\")[0].style.zoom = zoom;\n  }\n  function zoomOut() {\n    zoom -= 0.1;\n    Persistence.setItem(\"Zoom\", zoom);\n    document.querySelectorAll(\".front\")[0].style.zoom = zoom;\n  }\n  function gearTo() {\n    var xx = document.querySelectorAll(\"#settings-content\")[0];\n    if (xx.style.display === \"none\") {\n      xx.style.display = \"flex\";\n      window.scrollTo({left: 0, top: document.body.scrollHeight, behavior: \"smooth\"});\n    } else {\n      xx.style.display = \"none\";\n    }\n  }\n\n  document.getElementById(\"myCard\").onscroll = function() {\n    var scrollPosition = document.getElementById(\"myCard\").scrollTop;\n    Persistence.setItem(\"scroll\", scrollPosition);\n  };\n\n  function ToggleCheck(idx) {\n    var cont = document.querySelectorAll(\".container[data-idx='\" + idx + \"']\")[0];\n    var mycheckBox = cont.querySelector(\"input[type='checkbox']\");\n    mycheckBox.checked = !mycheckBox.checked;\n    cont.classList.toggle(\"check\");\n  }\n\n  function storeAnswerBox() {\n    answer = \"\";\n    var containers = document.querySelectorAll(\"#shuffle > .container\");\n    for (var i = 0; i < containers.length; i++) {\n      var cb = containers[i].querySelector(\"input[type='checkbox']