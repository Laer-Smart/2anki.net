{
  "name": "2anki-web",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.20.0"
  },
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "start": "cross-env REACT_SKIP_SENTRY=true vite",
    "dev": "cross-env NODE_OPTIONS=--max_old_space_size=4096 vite",
    "local": "cross-env REACT_APP_LOCALHOST=true vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint -c ../.oxlintrc.json src",
    "lint:fix": "oxfmt -c ../.oxfmtrc.json --write src",
    "schema:generate-types": "npx kanel -c .kanelrc.js",
    "generate:api-types": "swagger-typescript-api generate -p http://localhost:2020/docs/swagger.json -o ./src/generated --modular",
    "mock-server": "node mock-server/server.js",
    "test:e2e": "playwright test",
    "test:golden-path": "playwright test golden-path.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:with-mock": "cross-env PLAYWRIGHT_WITH_MOCK=true playwright test",
    "test:e2e:with-servers": "concurrently \"pnpm mock-server\" \"pnpm start\" --names \"mock,app\" --prefix-colors \"blue,green\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.1",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.101.0",
    "@xyflow/react": "^12.10.2",
    "canvas-confetti": "^1.9.4",
    "dagre": "^0.8.5",
    "date-fns": "^4.4.0",
    "get-notion-object-title": "^0.2.9",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-confetti": "^6.4.0",
    "react-cookie": "^8.1.2",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "universal-cookie": "^8.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/dagre": "^0.7.54",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.8",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "swagger-typescript-api": "^13.12.2",
    "swagger-ui-express": "^5.0.1",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.8"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
