{
  "name": "notion2anki-server",
  "description": "Go from Notion togglelists to Anki Cards easily!",
  "keywords": [
    "notion",
    "anki",
    "notion2anki"
  ],
  "author": "Alexander Alemayhu",
  "version": "2.0.0",
  "engines": {
    "node": ">=22.20.0"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "main": "main.js",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "pnpm run dev",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "arch": "depcruise src --config .dependency-cruiser.cjs",
    "dev": "concurrently --names server,web --prefix-colors magenta,cyan \"pnpm:dev:server\" \"pnpm:dev:web\"",
    "dev:server": "cross-env LOCAL_DEV=true tsx watch --env-file=.env src/server.ts",
    "dev:web": "pnpm --filter 2anki-web dev",
    "lint": "oxlint -c .oxlintrc.json src web/src",
    "lint:fix": "oxlint -c .oxlintrc.json --fix src web/src",
    "format": "oxfmt -c .oxfmtrc.json --threads 1 --write src web/src",
    "format:check": "oxfmt -c .oxfmtrc.json --threads 1 --check src web/src",
    "purge-js": "rm `find . -name '*.js'|grep -v node_modules`",
    "test:mock": "FORCE_BUILD=true ts-node lib/notion/_mock/build-mock-data.tsx",
    "dev-cleanup": "git clean -fd && find . -name '*.js.map' -type f -delete",
    "kanel": "kanel -c ./.kanelrc.js"
  },
  "license": "MIT",
  "dependencies": {
    "@2anki/csv-to-apkg": "^1.4.4",
    "@anthropic-ai/sdk": "^0.110.0",
    "@apple/app-store-server-library": "^3.1.0",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@notionhq/client": "^5.18.0",
    "@rolldown/binding-darwin-arm64": "1.1.5",
    "@sendgrid/mail": "^8.1.3",
    "@types/markdown-it": "^14.1.2",
    "@types/swagger-ui-express": "^4.1.8",
    "archiver": "^8.0.0",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.6",
    "crypto-js": "^4.2.0",
    "d3": "^7.9.0",
    "dockerode": "^5.0.0",
    "domhandler": "6.0.1",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "fflate": "^0.8.0",
    "find-remove": "^5.0.0",
    "fzstd": "^0.1.1",
    "get-notion-object-title": "^0.2.0",
    "google-auth-library": "^10.6.2",
    "highlight.js": "^11.11.1",
    "html-to-text": "^10.0.0",
    "http-proxy-middleware": "^4.0.0",
    "image-size": "^2.0.2",
    "jsonrepair": "^3.14.0",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.1.0",
    "mammoth": "^1.8.0",
    "markdown-it": "^14.1.1",
    "markdown-it-multimd-table": "^4.2.3",
    "markdown-it-task-lists": "^2.1.1",
    "markmap-view": "^0.18.12",
    "metascraper": "^5.50.1",
    "metascraper-description": "^5.50.1",
    "metascraper-image": "^5.50.1",
    "metascraper-logo-favicon": "^5.50.1",
    "metascraper-title": "^5.50.1",
    "metascraper-url": "^5.50.1",
    "morgan": "^1.11.0",
    "multer": "^2.0.1",
    "nodemailer": "^9.0.1",
    "p-limit": "^7.3.0",
    "pdf-parse": "1.1.1",
    "pg": "^8.11.3",
    "piscina": "^5.1.4",
    "puppeteer": "^25.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanitize-html": "^2.17.4",
    "sql.js": "^1.13.0",
    "stripe": "^22.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cheerio": "^1.0.0",
    "@types/cookie-parser": "^1.4.6",
    "@types/crypto-js": "^4.2.1",
    "@types/dockerode": "^4.0.1",
    "@types/dotenv": "^8.2.0",
    "@types/express": "^4.17.25",
    "@types/find-remove": "^2.0.1",
    "@types/html-to-text": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.0.6",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/sql.js": "^1.4.9",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/yauzl": "^3.3.0",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^18.0.0",
    "jest": "^30.2.0",
    "jszip": "^3.10.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.68.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "~6.0.3"
  },
  "pnpm": {
    "overrides": {
      "@types/express": "^4.17.25",
      "@types/express-serve-static-core": "^4.19.8",
      "rollup": ">=4.59.0",
      "rolldown": ">=1.0.2",
      "jsdom": "29.1.1",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "2anki-web>yaml": ">=2.8.3",
      "@xmldom/xmldom": ">=0.8.13 <0.9.0"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}